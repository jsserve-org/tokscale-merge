# ── tokscale-hub configuration ──────────────────────────────────────────────

# Port the hub listens on (default: 7171)
HUB_PORT=7171

# Comma-separated Bearer tokens for pushing to tokscale.ai.
# Each token submits independently — useful for pushing to multiple accounts.
# Copy tokens from devices that have logged in:
#   cat ~/.config/tokscale/credentials.json | grep '"token"'
HUB_TOKEN=token_account1,token_account2

# Upstream API (don't change unless tokscale.ai moves)
# HUB_UPSTREAM=https://tokscale.ai

# Optional comma-separated secrets — give each device its own secret.
# Devices must send Authorization: Bearer <their-secret> when submitting.
# If unset, all submissions on the network are accepted.
# HUB_SECRET=secret-laptop,secret-desktop,secret-workstation

# Set to "1" to auto-push to upstream after every device submission.
# Default is "0" — push manually with: curl -X POST http://localhost:7171/api/hub/push
# HUB_AUTO_PUSH=0

# Path to the JSON store file (default: ./hub-store.json)
# HUB_STORE_PATH=./hub-store.json
